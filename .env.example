# ──────────────────────────────────────────────────────────────────
# Failure Recovery Engine — environment template
# Copy to .env and edit. All values are validated at boot via zod.
# ──────────────────────────────────────────────────────────────────

NODE_ENV=development
LOG_LEVEL=info

# ── HTTP ──────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=*
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

# ── Auth ──────────────────────────────────────────────────────────
# Set AUTH_ENABLED=false to skip API key checks (dev only).
AUTH_ENABLED=true
DEFAULT_TENANT_SLUG=default

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=fre
POSTGRES_PASSWORD=fre_secret
POSTGRES_DB=failure_recovery
DATABASE_URL=postgresql://fre:fre_secret@localhost:5433/failure_recovery

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=
REDIS_TLS=false

# ── Worker ────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Idempotency ───────────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24

# ── Webhooks ──────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=5

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
# Browser-side API key for the dashboard. Issue from POST /v1/tenants/{id}/keys.
NEXT_PUBLIC_API_KEY=
